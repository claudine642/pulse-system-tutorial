{
  "general": [
    {
      "text": "后腰塌下去一截，肌肉松开又绷紧。",
      "body_part": "后腰",
      "sensation": "relax",
      "intensity": [
        0.3,
        0.7
      ],
      "toys": null,
      "positions": null
    },
    {
      "text": "小腹收紧了一下，呼吸浅了半拍。",
      "body_part": "小腹",
      "sensation": "tighten",
      "intensity": [
        0.2,
        0.6
      ],
      "toys": null,
      "positions": null
    },
    {
      "text": "脚趾蜷起来又松开，像在适应什么。",
